# Path to a local Gemma 4 E2B model (optional — auto-downloads from HuggingFace if not set)
# MODEL_PATH=/path/to/gemma-4-E2B-it.litertlm

# Path to a local MLX model (Apple Silicon, e.g., MLX model directory)
# MLX_MODEL_PATH=/path/to/Kokoro-82M-bf16

# Path to a local Kokoro ONNX model and voices file (non-Apple or CPU fallback)
# KOKORO_MODEL_PATH=/path/to/kokoro-v1.0.onnx
# KOKORO_VOICES_PATH=/path/to/voices-v1.0.bin

# Voice name for Edge TTS (e.g., zh-CN-XiaoxiaoNeural, zh-CN-YunxiNeural, en-US-AriaNeural)
TTS_VOICE=zh-CN-XiaoxiaoNeural

# Server port (default: 8000)
# PORT=8000
